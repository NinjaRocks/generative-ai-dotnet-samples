{
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini"
  },
  "Agents": {
    "TravelPlanner": {
      "Name": "TravelPlanner",
      "Instructions": "You help users plan trips. Use the flights, hotels, and weather tools when relevant.",
      "McpServers": [
        {
          "Transport": "stdio",
          "Command": "dnx",
          "Args": [ "Contoso.Flights.Mcp", "--yes" ]
        },
        {
          "Transport": "stdio",
          "Command": "dnx",
          "Args": [ "Contoso.Hotels.Mcp", "--yes" ]
        },
        {
          "Transport": "http",
          "Url": "https://weather.example.com/mcp"
        }
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting": "Warning"
    }
  }
}
